# Hiveward local environment example.
# Copy to .env.local for personal development. Do not commit real secrets.

# Optional single-port web/API dev server port.
HIVEWARD_PORT=10101

# Optional standalone API port. The default Vite dev server proxies API routes on HIVEWARD_PORT.
PORT=8787

# Optional browser-side API base URL when the web app is served separately.
# Leave empty for the default single-port local dev server.
VITE_API_BASE_URL=

# Runtime adapter mode: auto, mock, real, or gateway.
OPENCLAW_ADAPTER=auto

# Optional OpenClaw Gateway connection. Leave empty to use ~/.openclaw/openclaw.json or mock mode.
OPENCLAW_CONFIG_FILE=
OPENCLAW_CONFIG_PATH=
OPENCLAW_STATE_DIR=
OPENCLAW_PROFILE=
OPENCLAW_GATEWAY_URL=
OPENCLAW_GATEWAY_ORIGIN=
OPENCLAW_GATEWAY_LOCALE=zh-CN
OPENCLAW_GATEWAY_REQUEST_TIMEOUT_MS=20000
OPENCLAW_AGENT_START_TIMEOUT_MS=120000
OPENCLAW_CLI_ENTRY=

# Never commit real tokens or passwords.
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_GATEWAY_PASSWORD=

# Optional local SDK harness credentials and defaults.
CODEX_API_KEY=
CODEX_HOME=
CODEX_DEFAULT_MODEL=
HIVEWARD_CODEX_DEFAULT_MODEL=
ANTHROPIC_API_KEY=
CLAUDE_CODE_OAUTH_TOKEN=
CLAUDE_CODE_DEFAULT_MODEL=
HIVEWARD_CLAUDE_CODE_DEFAULT_MODEL=

# Optional local device identity and SDK runtime limits.
HIVEWARD_DEVICE_IDENTITY_FILE=
HIVEWARD_AGENT_SDK_TASK_TIMEOUT_MS=3600000
HIVEWARD_AGENT_SDK_MAX_CONCURRENCY=2

# Runtime state store.
# sqlite is the normal writable runtime. json-readonly is an explicit short-term read-only
# fallback for legacy data inspection. json is only a development escape hatch.
# When legacy JSON state exists, startup is fail-closed unless HIVEWARD_JSON_MIGRATION_MODE is dry-run or auto.
HIVEWARD_STORE_BACKEND=sqlite
HIVEWARD_SQLITE_PATH=data/hiveward.sqlite
HIVEWARD_JSON_MIGRATION_MODE=off
HIVEWARD_JSON_READONLY_FALLBACK=false
