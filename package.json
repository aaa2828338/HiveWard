{
  "name": "hiveward",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @hiveward/web",
    "build": "npm run build -w @hiveward/web && npm run typecheck -w @hiveward/api && npm run typecheck -w @hiveward/shared && npm run typecheck -w @hiveward/adapter",
    "check": "npm run check:boundaries && npm run typecheck -ws --if-present",
    "check:boundaries": "node scripts/check-boundaries.mjs",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.0"
  },
  "dependencies": {
    "@noble/ed25519": "^3.1.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@xyflow/react": "^12.9.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "lucide-react": "^0.468.0",
    "nanoid": "^5.1.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsx": "^4.20.0",
    "vite": "^7.0.0",
    "ws": "^8.20.1",
    "zod": "^4.1.0"
  }
}
