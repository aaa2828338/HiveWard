{
  "name": "hiveward",
  "version": "0.6.10",
  "description": "让101个Agent合作为你打工：调度 OpenClaw、Claude Code、Codex、Google CLI、Cursor CLI、OpenCode、Hermes 的 Agent Company 工作台。",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "npm@11.8.0",
  "engines": {
    "node": "^20.19.0 || >=22.12.0",
    "npm": ">=11.0.0 <12"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "setup": "npm install && npm run check:env",
    "dev": "npm run dev -w @hiveward/web",
    "build": "npm run build -w @hiveward/web && npm run typecheck -w @hiveward/api && npm run typecheck -w @hiveward/shared && npm run typecheck -w @hiveward/adapter && npm run build -w @hiveward/cli",
    "check": "npm run check:env && npm run check:boundaries && npm run typecheck --workspaces --if-present",
    "check:env": "node scripts/check-env.mjs",
    "check:boundaries": "node scripts/check-boundaries.mjs",
    "doctor:sqlite-lock": "node scripts/doctor-sqlite-lock.mjs",
    "migrate:sqlite": "node scripts/migrate-json-store-to-sqlite.mjs",
    "verify:sqlite": "node scripts/verify-sqlite-store.mjs",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.0"
  },
  "dependencies": {
    "@noble/ed25519": "^3.1.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@xyflow/react": "^12.9.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "lucide-react": "^0.468.0",
    "nanoid": "^5.1.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsx": "^4.20.0",
    "vite": "^7.0.0",
    "ws": "^8.20.1",
    "zod": "^4.1.0"
  }
}
